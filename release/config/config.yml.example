Log: # Logging output and verbosity settings.
  Level: warning # Log level: none, error, warning, info, debug.
  AccessPath: # Optional access log file path, for example /etc/XrayR/access.log. Leave empty to disable access file logging.
  ErrorPath: # Optional error log file path, for example /etc/XrayR/error.log. Leave empty to log errors to stdout/stderr.
  ShowErrorDetails: false # Whether to print detailed errors that may contain credentials; safe default is false.
DnsConfigPath: # Optional path to dns.json; see https://xtls.github.io/config/dns.html.
RouteConfigPath: # Optional path to route.json; see https://xtls.github.io/config/routing.html.
InboundConfigPath: # Optional path to custom_inbound.json; see https://xtls.github.io/config/inbound.html.
OutboundConfigPath: # Optional path to custom_outbound.json; see https://xtls.github.io/config/outbound.html.
ConnectionConfig: # Xray connection timeout and buffer tuning.
  Handshake: 4 # Handshake timeout in seconds.
  ConnIdle: 30 # Idle connection timeout in seconds.
  UplinkOnly: 2 # Timeout in seconds after downstream closes while uplink is still open.
  DownlinkOnly: 4 # Timeout in seconds after uplink closes while downstream is still open.
  BufferSize: 4 # Per-connection internal buffer size in KB; lower values reduce memory usage.
# MachineConfig enables Xboard server management mode.
# Use MachineConfig instead of Nodes; machine mode cannot be enabled together with static Nodes.
# XrayRP authenticates to Xboard with MachineID + Token, discovers servers bound to this machine,
# dynamically starts/stops per-node services, handles sync.nodes via a shared machine WebSocket,
# routes per-node events by node_id, reports node.status over WebSocket best-effort,
# and reports machine load to Xboard's server management page by base_config.push_interval.
# In Xboard, create/bind servers to this machine and copy the machine ID/token here.
# MachineConfig: # Xboard/NewV2board machine/server management mode configuration.
#   Enable: false # Set true to enable machine mode. When true, do not configure static Nodes below.
#   PanelType: "NewV2board" # Machine mode panel adapter. Use NewV2board for Xboard/NewV2board.
#   ApiHost: "https://panel.example.com" # Base URL of the Xboard/NewV2board panel, without a trailing slash.
#   MachineID: 1 # Machine ID from the Xboard server management page.
#   Token: "machine-token" # Machine token from Xboard. Keep this secret.
#   Timeout: 30 # HTTP API timeout in seconds for machine discovery and reports.
#   DiscoveryInterval: 60 # Fallback node discovery interval in seconds; Xboard base_config.pull_interval can update it at runtime.
#   ControllerConfig: # Shared controller defaults applied to every discovered server/node.
#     ListenIP: 0.0.0.0 # Local listen IP for inbound services created from discovered nodes.
#     SendIP: 0.0.0.0 # Local outbound source IP. Use 0.0.0.0 for the system default.
#     UpdatePeriodic: 60 # Fallback per-node sync/report interval in seconds when panel base_config is unavailable.
#     WebSocketConfig: # Shared machine WebSocket control-plane settings.
#       Enable: true # Enable shared machine WebSocket for sync.nodes, per-node mailbox routing, and node.status reports.
#       Endpoint: # Optional override; default resolves to <ApiHost>/api/v1/server/UniProxy/ws with machine_id + token.
#       HeartbeatInterval: 30 # WebSocket heartbeat interval in seconds.
#       ReconnectBackoff: 5 # Delay in seconds before reconnecting after a WebSocket disconnect.
#       ResyncOnReconnect: true # Submit a full node rediscovery/resync after WebSocket reconnects.
Nodes: # Static node list. Use this when MachineConfig is disabled.
  - PanelType: "SSPanel" # Panel type: SSPanel/SSpanel, NewV2board (also works with Xboard), PMpanel, Proxypanel, V2RaySocks, GoV2Panel, BunPanel.
    ApiConfig: # Panel API authentication and node identity settings.
      ApiHost: "http://127.0.0.1:667" # Base URL of the panel API, without a trailing slash.
      ApiKey: "123" # Panel API key/token for this node. Keep this secret.
      NodeID: 41 # Single node ID. For multiple nodes, add more entries under Nodes.
      NodeType: V2ray # Node type: V2ray, Vmess, Vless, Shadowsocks, Trojan, Shadowsocks-Plugin, Hysteria2, Tuic, AnyTLS, Socks, HTTP.
      Timeout: 30 # HTTP API timeout in seconds.
      EnableVless: false # For legacy V2ray-type panels, expose this node as VLESS instead of VMess.
      VlessFlow: "xtls-rprx-vision" # VLESS flow for direct TLS/REALITY over TCP. Keep empty for ws/grpc/httpupgrade/splithttp/xhttp.
      SpeedLimit: 0 # Local speed limit in Mbps. 0 means use panel value or disable local override.
      DeviceLimit: 0 # Local per-user device/IP limit. 0 means use panel value or disable local override.
      RuleListPath: # Optional path to a local audit rule list file, for example /etc/XrayR/rulelist.
      DisableCustomConfig: false # Disable custom config fetched from SSPanel-compatible panels.
    ControllerConfig: # Runtime behavior for this node.
      ListenIP: 0.0.0.0 # Local IP address for inbound listeners.
      SendIP: 0.0.0.0 # Local outbound source IP. Use 0.0.0.0 for the system default.
      UpdatePeriodic: 60 # Local fallback sync interval in seconds. For Xboard/NewV2board, base_config.pull_interval controls config sync and base_config.push_interval controls reports when provided.
      EnableDNS: false # Enable custom DNS config from DnsConfigPath.
      DNSType: AsIs # DNS strategy: AsIs, UseIP, UseIPv4, or UseIPv6.
      DisableSniffing: false # Disable protocol sniffing for inbound traffic.
      DisableUploadTraffic: false # Disable upload/download traffic reporting to the panel.
      DisableGetRule: false # Disable fetching audit/routing rules from the panel.
      DisableIVCheck: false # Disable Shadowsocks IV check for legacy compatibility. Keep false unless required.
      WebSocketConfig: # Optional WebSocket dual-active control plane settings.
        Enable: false # Enable WebSocket control plane. false keeps polling-only mode.
        Endpoint: # Optional endpoint override; default resolves to <ApiHost>/api/v1/server/UniProxy/ws.
        HeartbeatInterval: 30 # WebSocket heartbeat interval in seconds.
        ReconnectBackoff: 5 # Delay in seconds before reconnecting after a WebSocket disconnect.
        ResyncOnReconnect: true # Submit a full resync after WebSocket reconnects.
      EnableProxyProtocol: false # Enable PROXY protocol on supported TCP/WebSocket inbounds.
      AutoSpeedLimitConfig: # Automatic speed-limit punishment settings.
        Limit: 0 # Warning threshold in Mbps. 0 disables AutoSpeedLimit.
        WarnTimes: 0 # Number of consecutive warnings before limiting. 0 limits immediately after one warning.
        LimitSpeed: 0 # Speed limit applied to punished users in Mbps.
        LimitDuration: 0 # Punishment duration in minutes.
      GlobalDeviceLimitConfig: # Redis-backed global online device/IP limit across multiple XrayRP instances.
        Enable: false # Enable global device limit for users.
        RedisNetwork: tcp # Redis network type: tcp or unix.
        RedisAddr: 127.0.0.1:6379 # Redis server address, or Unix socket path when RedisNetwork is unix.
        RedisUsername: # Optional Redis username. Leave empty when Redis ACL username is not used.
        RedisPassword: YOUR PASSWORD # Redis password. Keep this secret.
        RedisDB: 0 # Redis database index.
        Timeout: 5 # Redis request timeout in seconds.
        Expiry: 60 # Redis online-device record expiry in seconds.
      EnableFallback: false # Enable fallback routing. Only supported for Trojan and VLESS.
      FallBackConfigs: # Fallback destinations used when EnableFallback is true.
        - SNI: # TLS SNI matcher. Empty matches any SNI.
          Alpn: # ALPN matcher. Empty matches any ALPN.
          Path: # HTTP path matcher. Empty matches any path.
          Dest: 80 # Required fallback destination; see https://xtls.github.io/config/features/fallback.html.
          ProxyProtocolVer: 0 # PROXY protocol version to send to fallback destination. 0 disables it.
      DisableLocalREALITYConfig: false # Ignore local REALITYConfigs and use panel-provided REALITY settings when available.
      EnableREALITY: false # Enable REALITY for supported VLESS/Trojan nodes.
      REALITYConfigs: # Local REALITY settings used when EnableREALITY is true and local REALITY is not disabled.
        Show: false # Whether to show REALITY debug information to clients.
        Dest: www.amazon.com:443 # Required REALITY destination, usually a real TLS site host:port.
        ProxyProtocolVer: 0 # PROXY protocol version sent to Dest. 0 disables it.
        ServerNames: # Required list of accepted server names. Wildcard is not supported.
          - www.amazon.com # One accepted REALITY server name.
        PrivateKey: YOUR_PRIVATE_KEY # Required private key. Generate with './XrayR x25519'.
        MinClientVer: # Optional minimum allowed Xray client version, format x.y.z.
        MaxClientVer: # Optional maximum allowed Xray client version, format x.y.z.
        MaxTimeDiff: 0 # Optional maximum client/server time difference in milliseconds. 0 disables the check.
        ShortIds: # Required list of accepted REALITY short IDs.
          - "" # Empty short ID option.
          - 0123456789abcdef # Example non-empty short ID.
      # CertConfig: # TLS certificate settings. Required for Hysteria2, Tuic, and AnyTLS nodes.
      #   CertMode: dns # Certificate source: none, file, http, tls, or dns.
      #   CertDomain: "node1.test.com" # Domain name used for certificate issue/load.
      #   CertFile: /etc/XrayR/cert/node1.test.com.cert # Certificate file path when CertMode is file.
      #   KeyFile: /etc/XrayR/cert/node1.test.com.key # Private key file path when CertMode is file.
      #   CertContent: # Inline certificate PEM content. Use only when the panel/local config provides certificate text directly.
      #   KeyContent: # Inline private key PEM content. Keep this secret.
      #   Provider: alidns # DNS provider for CertMode dns. See https://go-acme.github.io/lego/dns/.
      #   Email: test@me.com # ACME account email for certificate issuance.
      #   DNSEnv: # Environment variables required by the DNS provider.
      #     ALICLOUD_ACCESS_KEY: aaa # Example DNS provider access key. Keep this secret.
      #     ALICLOUD_SECRET_KEY: bbb # Example DNS provider secret key. Keep this secret.
      #   RejectUnknownSni: false # Reject TLS clients whose SNI does not match the configured certificate domain.

